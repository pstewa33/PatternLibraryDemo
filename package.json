{
  "name": "patternlibrarydemo",
  "version": "1.0.0",
  "description": "USWDS + Eleventy Pattern Library Demo",
  "type": "commonjs",
  "scripts": {
    "sass": "sass --watch src/assets/scss/styles.scss:src/assets/css/styles.css --load-path=node_modules/@uswds/uswds/packages",
    "build": "eleventy",
    "eleventy": "eleventy --serve",
    "start": "concurrently \"npm run sass\" \"npm run eleventy\""
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "concurrently": "^9.2.1",
    "sass": "^1.97.3"
  },
  "dependencies": {
    "@uswds/uswds": "^3.13.0"
  }
}
