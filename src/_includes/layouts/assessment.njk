            <p>
              {{ assessmentReport.mandate }}
            </p>
          </section>
          <section id="Chapters" role="tabpanel" class="tabs__panel basic-tab-panel">
            <h3>{{ chaptersList.section_label}}</h3>
            <p style="padding-bottom: 1rem; font-style: italic;">{{ chaptersList.before }}</p>
            {% include "components/prototype/accordion/accordion-chapters.md" %}
