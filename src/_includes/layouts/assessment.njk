            <h3>{{ rolesAndResponsibilitiesList.section_label }}</h3>
            {% include "components/prototype/accordion/accordion-roles.md" %}
          </section>
          <section id="Regions" role="tabpanel" class="tabs__panel basic-tab-panel">
            <h3>Regions</h3>
