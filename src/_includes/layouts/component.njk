<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <title>{{ title }}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@uswds/uswds@3.2.0/dist/css/uswds.min.css">
    <link rel="stylesheet" href="/assets/css/styles.css">
  </head>
  <body class="page-content">
    <div class="library-navbar">
      <div class="usa-logo" id="basic-logo">
        <a href="/"><em class="usa-logo__text">USWDS Component Library</em></a>
      </div>
      <ul class="nav-links">
        <li><a class="nav-link" href="/library/components/">Component Library</a></li>
        <li><a class="nav-link" href="/library/templates/">Templates</a></li>
      </ul>
    </div>
    <div class="grid-container-widescreen">
      <div class="grid-row grid-gap">
        <aside class="tablet:grid-col-3">
          <ul class="sidebar-nav">
            {% for component in collections.components %}
              {% if not component.data.hideFromSidebar %}
                <li><a href="{{ component.url }}">{{ component.data.title }}</a></li>
              {% endif %}
            {% endfor %}
          </ul>
        </aside>
        <main class="tablet:grid-col-9">
          <h1>{{ title }}</h1>
          <p>{{ description }}</p>
          <!-- Component preview -->
          <h2> Component Preview </h2>
          {% if component %}
            <div class="component-preview">
              {% include component %}
            </div>
            <!-- Component source code -->
            {% set accordionId = "code-" + title | slug %}
            <div class="usa-accordion code-example">
              <h4 class="usa-accordion__heading">
                <button
                  type="button"
                  class="usa-accordion__button"
                  aria-expanded="false"
                  aria-controls="{{ accordionId }}"
                >
                  View code
                </button>
              </h4>
              <div id="{{ accordionId }}" class="usa-accordion__content usa-prose">
                <pre><code class="language-html">
                  {{ component | rawFile | escape }}
                </code></pre>
              </div>
            </div>
            {% if variations %}
              {% for variation in variations %}
              <section class="component-variation">
                <h2>{{ variation.name }}</h2>

                <!-- Preview -->
                <div class="component-preview">
                  {% include variation.file %}
                </div>

                <!-- Accordion Code -->
                {% set accordionId = (title + "-" + variation.name) | slug %}

                <div class="usa-accordion code-example">
                  <h4 class="usa-accordion__heading">
                    <button
                      type="button"
                      class="usa-accordion__button"
                      aria-expanded="false"
                      aria-controls="{{ accordionId }}"
                    >
                      View code
                    </button>
                  </h4>
                  <div id="{{ accordionId }}" class="usa-accordion__content usa-prose">
                    <pre><code class="language-html">
                      {{ variation.file | rawFile | escape }}
                    </code></pre>
                  </div>
                </div>
              </section>
            {% endfor %}
          {% endif %}
          {% else %}
            <p style="color:red;">No component path provided</p>
          {% endif %}
          <div class="guidance">
            <h2>Guidance</h2>
            {{ content | safe }}
          </div>
          <div class="settings-table">
            <h3>{{ title }} Settings</h3>
            <table class="usa-table usa-table--borderless">
              <thead>
                <tr>
                  <th scope="col">Variable</th>
                  <th scope="col">Description</th>
                </tr>
              </thead>
              <tbody>
                {% for setting in settings %}
                <tr>
                  <td><code>{{ setting.name }}</code></td>
                  <td>{{ setting.description }}</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
          <div class="variant-settings-table">
            <h3>{{title}} Variants</h3>
            <table class="usa-table usa-table--borderless">
              <thead>
                <tr>
                  <th scope="col">Variant</th>
                  <th scope="col">Description</th>
                </tr>
              </thead>
              <tbody>
                {% for variant in variants %}
                <tr>
                  <td><code>{{ variant.name }}</code></td>
                  <td>{{ variant.description }}</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </main>
      </div>
    </div>

    <!-- USWDS JS -->
    <script src="https://cdn.jsdelivr.net/npm/@uswds/uswds@3.2.0/dist/js/uswds.min.js"></script>
    <script>
    document.addEventListener("DOMContentLoaded", function() {
      const links = document.querySelectorAll(".nav-link, .sidebar-nav a");
      const path = window.location.pathname;

      links.forEach(link => {
        // Normalize trailing slash
        let href = link.getAttribute("href");
        if (!href.endsWith("/")) href += "/";

        if (path.startsWith(href)) {
          link.classList.add("active");
          link.setAttribute("aria-current", "page");
        }
      });
    });
    </script>
  </body>
</html>