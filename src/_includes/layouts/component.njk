<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <title>{{ title }}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@uswds/uswds@3.2.0/dist/css/uswds.min.css">
    <link rel="stylesheet" href="/assets/css/styles.css">
  </head>
  <body class="page-content">
    <div class="navbar">
      <div class="usa-logo" id="basic-logo">
        <a href="/"><em class="usa-logo__text">USWDS Component Library</em></a>
      </div>
      <ul class="nav-links">
        <li><a class="nav-link" href="/library/components/">Component Library</a></li>
        <li><a class="nav-link" href="/library/templates/">Templates</a></li>
      </ul>
    </div>
    <div class="grid-container-widescreen">
      <div class="grid-row grid-gap">
        <aside class="tablet:grid-col-3">
          <ul class="sidebar-nav">
            {% for component in collections.components%}
              <li><a href="{{ component.url }}">{{ component.data.title }}</a></li>
            {% endfor %}
          </ul>
        </aside>
        <main class="tablet:grid-col-9">
          <h1>{{ title }}</h1>
          <!-- Component content goes here -->
          {{ content | safe }}
        </main>
      </div>
    </div>

    <!-- USWDS JS -->
    <script src="https://cdn.jsdelivr.net/npm/@uswds/uswds@3.2.0/dist/js/uswds.min.js"></script>
    <script>
      // Wait until the DOM is ready, then initialize all USWDS components
      document.addEventListener("DOMContentLoaded", function() {
        if (window.Uswds) {
          Uswds.initAll();
        }
      });
    </script>
  </body>
</html>