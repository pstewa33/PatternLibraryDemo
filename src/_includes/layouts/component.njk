<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <title>{{ title }}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@uswds/uswds@3.2.0/dist/css/uswds.min.css">
    <link rel="stylesheet" href="/assets/css/styles.css">
  </head>
  <body class="page-content">
    <div class="navbar">
      <div class="usa-logo" id="basic-logo">
        <a href="/"><em class="usa-logo__text">USWDS Component Library</em></a>
      </div>
      <ul class="nav-links">
        <li><a class="nav-link" href="/library/components/">Component Library</a></li>
        <li><a class="nav-link" href="/library/templates/">Templates</a></li>
      </ul>
    </div>
    <div class="grid-container-widescreen">
      <div class="grid-row grid-gap">
        <aside class="tablet:grid-col-3">
          <ul class="sidebar-nav">
            {% for component in collections.components%}
              <li><a href="{{ component.url }}">{{ component.data.title }}</a></li>
            {% endfor %}
          </ul>
        </aside>
        <main class="tablet:grid-col-9">
          <h1>{{ title }}</h1>
          <!-- Component preview -->
          {% if component %}
            <div class="component-preview">
              {% include component %}
            </div>
            <!-- Component source code -->
            {% set accordionId = "code-" + title | slug %}
            <div class="usa-accordion code-example">
              <h4 class="usa-accordion__heading">
                <button
                  type="button"
                  class="usa-accordion__button"
                  aria-expanded="false"
                  aria-controls="{{ accordionId }}"
                >
                  View code
                </button>
              </h4>
              <div id="{{ accordionId }}" class="usa-accordion__content usa-prose">
                <pre><code class="language-html">
                  {{ component | rawFile | escape }}
                </code></pre>
              </div>
            </div>
            {% if variations %}
              {% for variation in variations %}
              <section class="component-variation">
                <h2>{{ variation.name }}</h2>

                <!-- Preview -->
                <div class="component-preview">
                  {% include variation.file %}
                </div>

                <!-- Accordion Code -->
                {% set accordionId = (title + "-" + variation.name) | slug %}

                <div class="usa-accordion code-example">
                  <h4 class="usa-accordion__heading">
                    <button
                      type="button"
                      class="usa-accordion__button"
                      aria-expanded="false"
                      aria-controls="{{ accordionId }}"
                    >
                      View code
                    </button>
                  </h4>
                  <div id="{{ accordionId }}" class="usa-accordion__content usa-prose">
                    <pre><code class="language-html">
                      {{ variation.file | rawFile | escape }}
                    </code></pre>
                  </div>
                </div>
              </section>
            {% endfor %}
          {% endif %}
          {% else %}
            <p style="color:red;">No component path provided</p>
          {% endif %}
        </main>
      </div>
    </div>

    <!-- USWDS JS -->
    <script src="https://cdn.jsdelivr.net/npm/@uswds/uswds@3.2.0/dist/js/uswds.min.js"></script>
    <script>
      // Wait until the DOM is ready, then initialize all USWDS components
      document.addEventListener("DOMContentLoaded", function() {
        if (window.Uswds) {
          Uswds.initAll();
        }
      });
    </script>
  </body>
</html>